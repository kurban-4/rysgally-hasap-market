{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "rysgally-hasap-market",
  "version": "0.5.0",
  "identifier": "com.annagurban.rysgally-hasap-market",
  "build": {
    "beforeDevCommand": "cd src-tauri/resources/rysgally-hasap-market && php -S 0.0.0.0:8001 -t public server.php &",
    "beforeBuildCommand": "cd src-tauri/resources/rysgally-hasap-market && php artisan config:cache && php artisan route:cache && php artisan view:cache",
    "devUrl": "http://127.0.0.1:8001",
    "frontendDist": "http://127.0.0.1:8001"
  },
  "bundle": {
    "resources": [
      "resources/rysgally-hasap-market/**/*",
      "resources/rysgally-hasap-market/.env",
      "resources/rysgally-hasap-market/server.php",
      "binaries/php.ini"
    ],
    "externalBin": [
      "binaries/php"
    ],
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/annagurban/rysgally-hasap/releases/latest/download/latest.json"
      ],
      "pubkey": "RWQGoyosV2pIpN1nsc7pzzMMJLEj5gqkZF5yNBlktv7wfduk6yWX/J/o"
    }
  }
}